---
interface Props {
  command: string;
  title: string;
}

const { command, title } = Astro.props;
---

<header class="text-center mb-20">
  <p class="font-[family-name:var(--font-mono)] text-pineapple-400 text-sm mb-4">{command}</p>
  <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-bold">
    {title}
  </h2>
</header>
