---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EventArticle from '../components/EventArticle.astro';
import ReasonCard from '../components/ReasonCard.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Hero />

  <main id="events" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeader command="ls -la ./events/" title="Nasza oferta" />

      <div class="space-y-16 md:space-y-24">

        <EventArticle
          id="vabank"
          index="01"
          title="Va Bank IT"
          subtitle="Parodia teleturnieju, w której nikt nie jest bezpieczny"
          duration="45 min (1 rozgrywka)"
          description={`Trzech uczestników walczy o wygraną w parodii popularnego teleturnieju "Va Banque". Kategorie pytań sprawiają wrażenie wiedzy ogólnej, ale kryją w sobie prawdziwie nerdowskie zagadki.`}
        >
          <div class="grid md:grid-cols-3 gap-3 mb-8">
            <div class="overflow-hidden rounded-lg border border-dark-600 md:col-span-2 md:row-span-2">
              <img src="/img/vabank-it-01.webp" alt="Va Bank IT" class="w-full h-full object-cover" fetchpriority="high" />
            </div>
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/vabank-it-02.webp" alt="Va Bank IT" class="w-full h-full object-cover" fetchpriority="high" />
            </div>
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/vabank-it-03.webp" alt="Va Bank IT" class="w-full h-full object-cover" fetchpriority="high" />
            </div>
          </div>
          <div class="mb-8">
            <p class="font-[family-name:var(--font-mono)] text-pineapple-400 text-sm mb-4">// przykładowe pytania</p>
            <div class="grid md:grid-cols-3 gap-4">
              <div class="bg-dark-800 border border-dark-600 rounded-lg p-4">
                <p class="text-pineapple-400 text-xs font-[family-name:var(--font-mono)] uppercase tracking-wider mb-2">Matematyka</p>
                <p class="text-stone-200 font-medium mb-2">SSH + DNS = ?</p>
                <p class="text-stone-500 text-sm">dodawanie portów: 22 + 53 = 75</p>
              </div>
              <div class="bg-dark-800 border border-dark-600 rounded-lg p-4">
                <p class="text-pineapple-400 text-xs font-[family-name:var(--font-mono)] uppercase tracking-wider mb-2">Geografia</p>
                <p class="text-stone-200 font-medium mb-2">Jaki kraj ma domenę .aq?</p>
                <p class="text-stone-500 text-sm">Antarktyda (TLD)</p>
              </div>
              <div class="bg-dark-800 border border-dark-600 rounded-lg p-4">
                <p class="text-pineapple-400 text-xs font-[family-name:var(--font-mono)] uppercase tracking-wider mb-2">Muzyka</p>
                <p class="text-stone-200 font-medium mb-2">Mozart czy Pokemony?</p>
                <p class="text-stone-500 text-sm">puszczamy dźwięk i zgadujemy</p>
              </div>
            </div>
          </div>
          <div class="bg-dark-800 border border-dark-600 rounded-lg p-6">
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>"Koło ratunkowe" to telefon do mamy prowadzącego</span>
              </li>
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>"Koło ratunkowe" to Wikipedia... ale tylko czeska</span>
              </li>
            </ul>
          </div>
          <p class="mt-4 text-pineapple-400 font-[family-name:var(--font-mono)] text-sm">
            * Da się zrobić dwie rozgrywki bez problemu!
          </p>
        </EventArticle>

        <EventArticle
          id="hackercourt"
          index="02"
          title="Hacker Court"
          subtitle="Cyberprzestępczość spotyka dramat sądowy"
          duration="45 min - 1h"
          description="Uczestnicy wcielają się w rolę ławy przysięgłych. Dwaj prawnicy zmierzą się w fikcyjnej sprawie, w której oskarżonym jest biedny haker. To doskonała okazja, by uczyć się na cudzych błędach i zgłębić mechanizmy postępowania prawnego w świecie cyberprzestępczości."
        >
          <div class="grid md:grid-cols-2 gap-3 mb-8">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/hacker-court-01.webp" alt="Hacker Court" class="w-full object-cover" loading="lazy" />
            </div>
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/hacker-court-02.webp" alt="Hacker Court" class="w-full object-cover" loading="lazy" />
            </div>
          </div>
        </EventArticle>

        <EventArticle
          id="codekata"
          index="03"
          title="Code Kata: Hackserver"
          subtitle="Nie chodzi o rozwiązanie - chodzi o drogę"
          duration="4h - 6h"
          description="Code kata to ćwiczenie, które pomaga programistom doskonalić umiejętności poprzez powtarzanie. Hackserver to zestaw prostych ćwiczeń ze świata mikrousług i algorytmów - do rozwiązania w krótkim czasie, w dowolnej technologii. A to wszystko na punkty!"
        >
          <div class="mb-8">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/code-kata-01.webp" alt="Code Kata: Hackserver" class="w-full object-cover" loading="lazy" />
            </div>
          </div>
          <div class="bg-dark-800 border border-dark-600 rounded-lg p-6">
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>Dowolna technologia</span>
              </li>
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>Ćwiczenia z mikrousług i algorytmów</span>
              </li>
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>Rywalizacja na punkty</span>
              </li>
            </ul>
          </div>
        </EventArticle>

        <EventArticle
          id="hackmerlin"
          index="04"
          title="Hack Merlin"
          subtitle="Prompt injection - przechytrz Merlina!"
          duration="cały dzień"
          description="hackmerlin.io (wersja webowa) albo secure-code-game (wersja CLI) - to gra w prompt injection. Zadawaj sprytne pytania i spraw, aby Merlin zdradził hasło do każdego poziomu. Merlin staje się mądrzejszy z każdym poziomem. Czy uda Ci się pokonać Level 7?"
        >
          <div class="overflow-hidden rounded-lg border border-dark-600 mb-3">
            <img src="/img/secure-code-game-01.gif" alt="Secure Code Game" class="w-full object-contain" loading="lazy" />
          </div>
          <div class="hidden md:grid md:grid-cols-2 gap-3 mb-8">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/hackmerlin-01.webp" alt="Hack Merlin" class="w-full object-contain" loading="lazy" />
            </div>
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/hackmerlin-02.webp" alt="Hack Merlin" class="w-full object-contain" loading="lazy" />
            </div>
          </div>
          <div class="md:hidden relative mb-8" x-data="{ current: 0, total: 2, touchStartX: 0 }" @touchstart="touchStartX = $event.touches[0].clientX" @touchend="if (touchStartX - $event.changedTouches[0].clientX > 50) current = (current + 1) % total; if (touchStartX - $event.changedTouches[0].clientX < -50) current = (current - 1 + total) % total;">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <div class="flex transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${current * 100}%)`">
                <img src="/img/hackmerlin-01.webp" alt="Hack Merlin" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/hackmerlin-02.webp" alt="Hack Merlin" class="w-full flex-shrink-0 object-contain" loading="lazy" />
              </div>
            </div>
            <button @click="current = current > 0 ? current - 1 : total - 1" class="hidden md:flex absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Poprzednie zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </button>
            <button @click="current = current < total - 1 ? current + 1 : 0" class="hidden md:flex absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Następne zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </button>
            <div class="flex justify-center gap-2 mt-3">
              <template x-for="i in total">
                <button @click="current = i - 1" :class="current === i - 1 ? 'bg-pineapple-400' : 'bg-dark-600'" class="w-2 h-2 rounded-full transition-colors"></button>
              </template>
            </div>
          </div>
          <div class="bg-dark-800 border border-dark-600 rounded-lg p-6">
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>Wersja webowa oraz jako kod</span>
              </li>
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>7 poziomów trudności</span>
              </li>
            </ul>
          </div>
        </EventArticle>

        <EventArticle
          id="cssbattles"
          index="05"
          title="CSS Battles"
          subtitle="Esport dla programistów i programistek!"
          duration="W zależności od liczby uczestników"
          description="Formuła turniejowa (drabinka), w której uczestnicy po kolei mają za zadanie odwzorować kodem CSS dokładnie to, co widzą na obrazku - i to na czas! Napięcie, epicka muzyka w tle i emocje po sam sufit. Działa dobrze online (Twitch/YouTube), ale jeszcze lepiej na żywo!"
        >
          <div class="relative mb-8" x-data="{ current: 0, total: 2, touchStartX: 0 }" @touchstart="touchStartX = $event.touches[0].clientX" @touchend="if (touchStartX - $event.changedTouches[0].clientX > 50) current = (current + 1) % total; if (touchStartX - $event.changedTouches[0].clientX < -50) current = (current - 1 + total) % total;">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <div class="flex transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${current * 100}%)`">
                <img src="/img/cssbattles-02.webp" alt="CSS Battles" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/cssbattles-03.webp" alt="CSS Battles" class="w-full flex-shrink-0 object-cover" loading="lazy" />
              </div>
            </div>
            <button @click="current = current > 0 ? current - 1 : total - 1" class="hidden md:flex absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Poprzednie zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </button>
            <button @click="current = current < total - 1 ? current + 1 : 0" class="hidden md:flex absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Następne zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </button>
            <div class="flex justify-center gap-2 mt-3">
              <template x-for="i in total">
                <button @click="current = i - 1" :class="current === i - 1 ? 'bg-pineapple-400' : 'bg-dark-600'" class="w-2 h-2 rounded-full transition-colors"></button>
              </template>
            </div>
          </div>
        </EventArticle>

        <EventArticle
          id="spacepanic"
          index="06"
          title="Space Panic"
          subtitle="Cała firma na jednym pokładzie"
          duration="30 min - 1h"
          description="Wspólna gra online dla całej firmy! Rozwiązujecie zadania i zdobywacie punkty, tak aby załoga rakiety dotarła do celu. Idealna integracja, w której liczy się współpraca i szybkie myślenie."
        >
          <div class="md:hidden relative mb-8" x-data="{ current: 0, total: 3, touchStartX: 0 }" @touchstart="touchStartX = $event.touches[0].clientX" @touchend="if (touchStartX - $event.changedTouches[0].clientX > 50) current = (current + 1) % total; if (touchStartX - $event.changedTouches[0].clientX < -50) current = (current - 1 + total) % total;">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <div class="flex transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${current * 100}%)`">
                <img src="/img/space-panic-01.webp" alt="Space Panic" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/space-panic-02.webp" alt="Space Panic" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/space-panic-03.webp" alt="Space Panic" class="w-full flex-shrink-0 object-contain" loading="lazy" />
              </div>
            </div>
            <button @click="current = current > 0 ? current - 1 : total - 1" class="hidden md:flex absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Poprzednie zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </button>
            <button @click="current = current < total - 1 ? current + 1 : 0" class="hidden md:flex absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Następne zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </button>
            <div class="flex justify-center gap-2 mt-3">
              <template x-for="i in total">
                <button @click="current = i - 1" :class="current === i - 1 ? 'bg-pineapple-400' : 'bg-dark-600'" class="w-2 h-2 rounded-full transition-colors"></button>
              </template>
            </div>
          </div>
          <div class="hidden md:grid md:grid-cols-2 gap-3 mb-8 items-start">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/space-panic-01.webp" alt="Space Panic" class="w-full object-contain" loading="lazy" />
            </div>
            <div class="relative" x-data="{ current: 0, total: 2, touchStartX: 0 }" @touchstart="touchStartX = $event.touches[0].clientX" @touchend="if (touchStartX - $event.changedTouches[0].clientX > 50) current = (current + 1) % total; if (touchStartX - $event.changedTouches[0].clientX < -50) current = (current - 1 + total) % total;">
              <div class="overflow-hidden rounded-lg border border-dark-600">
                <div class="flex transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${current * 100}%)`">
                  <img src="/img/space-panic-02.webp" alt="Space Panic" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                  <img src="/img/space-panic-03.webp" alt="Space Panic" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                </div>
              </div>
              <button @click="current = current > 0 ? current - 1 : total - 1" class="hidden md:flex absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Poprzednie zdjęcie">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              </button>
              <button @click="current = current < total - 1 ? current + 1 : 0" class="hidden md:flex absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Następne zdjęcie">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </button>
              <div class="flex justify-center gap-2 mt-3">
                <template x-for="i in total">
                  <button @click="current = i - 1" :class="current === i - 1 ? 'bg-pineapple-400' : 'bg-dark-600'" class="w-2 h-2 rounded-full transition-colors"></button>
                </template>
              </div>
            </div>
          </div>
          <div class="bg-dark-800 border border-dark-600 rounded-lg p-6">
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>Gra przeglądarkowa - wystarczy link</span>
              </li>
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>Skaluje się do setek uczestników</span>
              </li>
              <li class="flex items-start gap-3 text-stone-300">
                <span class="text-pineapple-400 mt-0.5 font-[family-name:var(--font-mono)]">&gt;</span>
                <span>Wspólny cel = wspólna zabawa</span>
              </li>
            </ul>
          </div>
        </EventArticle>

        <EventArticle
          id="phishing"
          index="07"
          title="Phishing Game"
          subtitle="Nauka przez zabawę - czy to phishing?"
          duration="30 min - 1h"
          description="Zgadywanie i zbieranie punktów - czy dany e-mail to phishing, czy prawdziwa wiadomość? Interaktywna gra, która uczy rozpoznawać zagrożenia w skrzynce mailowej. Świetna forma budowania świadomości bezpieczeństwa w całej organizacji."
        >
          <div class="md:hidden relative mb-8" x-data="{ current: 0, total: 5, touchStartX: 0 }" @touchstart="touchStartX = $event.touches[0].clientX" @touchend="if (touchStartX - $event.changedTouches[0].clientX > 50) current = (current + 1) % total; if (touchStartX - $event.changedTouches[0].clientX < -50) current = (current - 1 + total) % total;">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <div class="flex transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${current * 100}%)`">
                <img src="/img/phishing-game-1.webp" alt="Phishing Game" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/phishing-game-2.webp" alt="Phishing Game" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/phishing-game-3.webp" alt="Phishing Game" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/phishing-game-4.webp" alt="Phishing Game" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                <img src="/img/phishing-game-5.webp" alt="Phishing Game" class="w-full flex-shrink-0 object-contain" loading="lazy" />
              </div>
            </div>
            <button @click="current = current > 0 ? current - 1 : total - 1" class="hidden md:flex absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Poprzednie zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </button>
            <button @click="current = current < total - 1 ? current + 1 : 0" class="hidden md:flex absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-dark-900/70 border border-dark-600 text-stone-300 items-center justify-center hover:bg-dark-900 transition-colors" aria-label="Następne zdjęcie">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </button>
            <div class="flex justify-center gap-2 mt-3">
              <template x-for="i in total">
                <button @click="current = i - 1" :class="current === i - 1 ? 'bg-pineapple-400' : 'bg-dark-600'" class="w-2 h-2 rounded-full transition-colors"></button>
              </template>
            </div>
          </div>
          <div class="hidden md:grid md:grid-cols-2 gap-3 mb-8 items-start">
            <div class="overflow-hidden rounded-lg border border-dark-600">
              <img src="/img/phishing-game-1.webp" alt="Phishing Game" class="w-full object-contain" loading="lazy" />
            </div>
            <div class="relative" x-data="{ current: 0, total: 4, touchStartX: 0 }" @touchstart="touchStartX = $event.touches[0].clientX" @touchend="if (touchStartX - $event.changedTouches[0].clientX > 50) current = (current + 1) % total; if (touchStartX - $event.changedTouches[0].clientX < -50) current = (current - 1 + total) % total;">
              <div class="overflow-hidden rounded-lg border border-dark-600">
                <div class="flex transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${current * 100}%)`">
                  <img src="/img/phishing-game-2.webp" alt="Phishing Game" class="w-full flex-shrink-0 object-contain" loading="lazy" />
                  <img src="/img/phishing-game-3.webp" alt="Phishing Game" class="w-full flex-shrink-0 object-contain" loading="lazy" />
